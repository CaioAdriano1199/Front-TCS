{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "relic",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets"
  }
}